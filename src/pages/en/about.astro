---
import BaseLayout from "../../layouts/BaseLayout.astro";

const principles = [
  {
    title: "Build with clarity",
    description:
      "I care about software that is easy to understand, extend, and maintain over time.",
  },
  {
    title: "Think beyond visuals",
    description:
      "A good product is not only attractive. It must be fast, useful, accessible, and aligned with real goals.",
  },
  {
    title: "Keep learning deeply",
    description:
      "I am constantly strengthening my foundation in web development, backend systems, Linux, C, and software architecture.",
  },
];

const stack = [
  "Astro",
  "Tailwind CSS",
  "TypeScript",
  "Laravel",
  "MySQL",
  "Flutter",
  "Dart",
  "Linux",
  "Git",
  "PHP",
];
---

<BaseLayout
  title="About — Julio Andrei"
  description="Learn more about Julio Andrei, a freelance software developer based in Puebla, Mexico."
>
  <section
    class="mx-auto w-full max-w-7xl px-5 py-20 sm:px-8 lg:px-10 lg:py-28"
  >
    <div class="grid gap-14 lg:grid-cols-[0.85fr_1.15fr] lg:gap-20">
      <aside>
        <p
          class="font-mono text-sm font-semibold uppercase tracking-[0.18em] text-brand-400"
        >
          About
        </p>

        <h1
          class="mt-5 text-4xl font-semibold leading-tight tracking-[-0.04em] text-white sm:text-6xl"
        >
          I build practical software with care and intention.
        </h1>

        <p class="mt-6 text-lg leading-8 text-zinc-400">
          I am Julio Andrei, a software developer based in Puebla, Mexico,
          focused on building professional websites, web applications, APIs, and
          mobile experiences.
        </p>
      </aside>

      <div class="space-y-8">
        <div
          class="rounded-3xl border border-white/10 bg-white/[0.025] p-6 sm:p-8"
        >
          <h2 class="text-2xl font-semibold tracking-tight text-white">
            What drives my work
          </h2>

          <div class="mt-6 space-y-5 text-zinc-400">
            <p>
              I like building software that has a clear purpose. Not just pages
              that look good for a screenshot, but digital products that help
              people understand a service, manage information, contact a
              business, or improve a workflow.
            </p>

            <p>
              My current focus is freelance software development: professional
              websites, landing pages, web systems, backend APIs, and mobile
              interfaces for businesses and independent professionals.
            </p>

            <p>
              I also care about the technical foundations behind the work: clean
              structure, readable code, performance, responsive design, and
              maintainable architecture.
            </p>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-3">
          {
            principles.map((principle) => (
              <article class="rounded-3xl border border-white/10 bg-white/[0.025] p-6">
                <h3 class="font-semibold text-white">{principle.title}</h3>

                <p class="mt-3 text-sm leading-7 text-zinc-400">
                  {principle.description}
                </p>
              </article>
            ))
          }
        </div>

        <div
          class="rounded-3xl border border-white/10 bg-white/[0.025] p-6 sm:p-8"
        >
          <h2 class="text-2xl font-semibold tracking-tight text-white">
            Technologies I work with
          </h2>

          <div class="mt-6 flex flex-wrap gap-2">
            {
              stack.map((item) => (
                <span class="rounded-full border border-white/10 bg-white/[0.035] px-3 py-1 text-sm font-medium text-zinc-400">
                  {item}
                </span>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
