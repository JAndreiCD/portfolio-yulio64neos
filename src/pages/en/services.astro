---
import BaseLayout from "../../layouts/BaseLayout.astro";

const services = [
  {
    title: "Professional websites",
    description:
      "A polished website for businesses, independent professionals, or brands that need a clear and trustworthy online presence.",
    deliverables: [
      "Responsive website design",
      "Service or product pages",
      "Clear contact flow",
      "Performance-focused implementation",
    ],
  },
  {
    title: "Landing pages",
    description:
      "Focused pages designed to present one offer, campaign, service, or product with a clear call to action.",
    deliverables: [
      "Conversion-focused structure",
      "Mobile-first layout",
      "Copy structure and sections",
      "Contact or lead capture flow",
    ],
  },
  {
    title: "Web applications",
    description:
      "Custom interfaces and internal tools for teams that need to manage information, workflows, or business processes.",
    deliverables: [
      "Dashboards",
      "Admin panels",
      "Data-driven interfaces",
      "Frontend and backend integration",
    ],
  },
  {
    title: "Backend & APIs",
    description:
      "Reliable backend foundations for authentication, business logic, database operations, and integrations.",
    deliverables: [
      "REST API development",
      "Authentication flows",
      "Database structure",
      "Integration with frontend or mobile apps",
    ],
  },
  {
    title: "Mobile experiences",
    description:
      "Cross-platform mobile interfaces focused on usability, maintainability, and connection with backend services.",
    deliverables: [
      "Flutter app interfaces",
      "API integration",
      "Device feature integration",
      "Mobile-friendly product flows",
    ],
  },
  {
    title: "Maintenance & improvements",
    description:
      "Support for existing websites or systems that need improvements, cleanup, fixes, or modernization.",
    deliverables: [
      "Bug fixes",
      "UI improvements",
      "Performance cleanup",
      "Code structure improvements",
    ],
  },
];

const processSteps = [
  {
    step: "01",
    title: "Discovery",
    description:
      "We clarify the goal, audience, current problems, required features, and business context.",
  },
  {
    step: "02",
    title: "Scope",
    description:
      "I define a practical plan with pages, features, deliverables, priorities, and technical direction.",
  },
  {
    step: "03",
    title: "Build",
    description:
      "I develop the project with attention to responsive design, maintainable code, and clear structure.",
  },
  {
    step: "04",
    title: "Review & launch",
    description:
      "We review the result, adjust details, prepare deployment, and leave the project ready to use.",
  },
];
---

<BaseLayout
  title="Services — Julio Andrei"
  description="Professional websites, landing pages, web applications, APIs, mobile experiences, and maintenance services."
>
  <section
    class="mx-auto w-full max-w-7xl px-5 py-20 sm:px-8 lg:px-10 lg:py-28"
  >
    <div class="max-w-4xl">
      <p
        class="font-mono text-sm font-semibold uppercase tracking-[0.18em] text-brand-400"
      >
        Services
      </p>

      <h1
        class="mt-5 text-4xl font-semibold leading-tight tracking-[-0.04em] text-white sm:text-6xl"
      >
        Software services for real business needs.
      </h1>

      <p class="mt-6 max-w-3xl text-lg leading-8 text-zinc-400">
        I help businesses, independent professionals, and growing teams build
        websites, applications, and digital tools that are clear, fast,
        responsive, and maintainable.
      </p>
    </div>

    <div class="mt-16 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {
        services.map((service) => (
          <article class="group rounded-3xl border border-white/10 bg-white/[0.025] p-6 transition duration-300 hover:-translate-y-1 hover:border-brand-400/40 hover:bg-white/[0.04] sm:p-8">
            <div class="mb-8 h-2 w-12 rounded-full bg-brand-400/80 shadow-[0_0_20px_rgba(60,227,156,0.45)]" />

            <h2 class="text-2xl font-semibold tracking-tight text-white">
              {service.title}
            </h2>

            <p class="mt-4 leading-7 text-zinc-400">{service.description}</p>

            <ul class="mt-7 space-y-3">
              {service.deliverables.map((item) => (
                <li class="flex gap-3 text-sm text-zinc-400">
                  <span
                    class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-brand-400"
                    aria-hidden="true"
                  />
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </section>

  <section class="border-t border-white/8 bg-white/[0.015]">
    <div class="mx-auto w-full max-w-7xl px-5 py-20 sm:px-8 lg:px-10 lg:py-28">
      <div class="grid gap-12 lg:grid-cols-[0.8fr_1.2fr] lg:gap-16">
        <div>
          <p
            class="font-mono text-sm font-semibold uppercase tracking-[0.18em] text-brand-400"
          >
            Process
          </p>

          <h2
            class="mt-5 text-3xl font-semibold leading-tight tracking-[-0.03em] text-white sm:text-5xl"
          >
            A clear process from idea to delivery.
          </h2>

          <p class="mt-6 leading-8 text-zinc-400">
            I prefer practical planning, honest scope, and steady execution. The
            goal is not to overcomplicate the project, but to build the right
            thing with a structure that can grow.
          </p>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          {
            processSteps.map((item) => (
              <article class="rounded-3xl border border-white/10 bg-zinc-950/40 p-6">
                <p class="font-mono text-sm text-brand-400">{item.step}</p>

                <h3 class="mt-5 text-xl font-semibold text-white">
                  {item.title}
                </h3>

                <p class="mt-4 leading-7 text-zinc-400">{item.description}</p>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-white/8">
    <div class="mx-auto w-full max-w-7xl px-5 py-20 sm:px-8 lg:px-10 lg:py-28">
      <div
        class="rounded-[2rem] border border-brand-400/20 bg-brand-400/10 p-8 sm:p-10 lg:p-14"
      >
        <div class="grid gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-end">
          <div>
            <p
              class="font-mono text-sm font-semibold uppercase tracking-[0.18em] text-brand-300"
            >
              Start with clarity
            </p>

            <h2
              class="mt-5 max-w-3xl text-3xl font-semibold leading-tight tracking-[-0.03em] text-white sm:text-5xl"
            >
              Not sure what your project needs yet?
            </h2>

            <p class="mt-6 max-w-2xl leading-8 text-zinc-300">
              You do not need to have every detail figured out. Tell me what you
              want to improve, launch, or build, and we can define a clear first
              version.
            </p>
          </div>

          <div class="flex flex-col gap-3 sm:flex-row lg:justify-end">
            <a
              href="/en/contact"
              class="inline-flex min-h-12 items-center justify-center rounded-full bg-brand-400 px-6 font-semibold text-zinc-950 transition hover:bg-brand-300"
            >
              Start a project
            </a>

            <a
              href="/en/projects"
              class="inline-flex min-h-12 items-center justify-center rounded-full border border-white/15 bg-white/[0.04] px-6 font-semibold text-white transition hover:border-white/30 hover:bg-white/[0.08]"
            >
              View projects
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
