---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Services - Julio Andrei"
  description="Web development, software systems, APIs, and mobile development services."
>
  <section class="mx-auto w-full max-w-7xl px-5 py-20 sm:px-8 lg:px-10">
    <p class="font-mono text-sm uppercase tracking-widest text-brand-400">
      Services
    </p>

    <h1
      class="mt-4 text-4xl font-semibold tracking-tight text-white sm:text-6xl"
    >
      Software services for real business needs.
    </h1>
  </section>
</BaseLayout>
