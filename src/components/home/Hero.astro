---
import LocalTime from "../ui/LocalTime.astro";
---

<section class="relative overflow-hidden">
  <div
    class="mx-auto grid w-full max-w-7xl items-center gap-14 px-5 py-20 sm:px-8 sm:py-28 lg:grid-cols-[1.2fr_0.8fr] lg:px-10 lg:py-36"
  >
    <div>
      <div class="mb-8 xl:hidden">
        <LocalTime />
      </div>

      <p
        class="mb-5 font-mono text-sm font-semibold uppercase tracking-[0.18em] text-brand-400"
      >
        Freelance software developer
      </p>

      <h1
        class="max-w-4xl text-4xl font-semibold leading-[1.08] tracking-[-0.04em] text-white sm:text-6xl lg:text-7xl"
      >
        Digital products built with{' '}
        <span class="text-brand-400">purpose</span>, not noise.
      </h1>

      <p class="mt-7 max-w-2xl text-base leading-8 text-zinc-400 sm:text-lg">
        I design and develop professional websites, web applications, APIs, and
        mobile experiences for businesses and growing teams.
      </p>

      <div class="mt-10 flex flex-col gap-3 sm:flex-row">
        <a
          href="/projects"
          class="inline-flex min-h-12 items-center justify-center rounded-full bg-brand-400 px-6 font-semibold text-zinc-950 transition hover:bg-brand-300"
        >
          Explore my work
        </a>

        <a
          href="/contact"
          class="inline-flex min-h-12 items-center justify-center rounded-full border border-white/12 bg-white/[0.03] px-6 font-semibold text-white transition hover:border-white/25 hover:bg-white/[0.06]"
        >
          Start a project
        </a>
      </div>
    </div>

    <aside
      class="rounded-3xl border border-white/10 bg-white/[0.035] p-6 shadow-2xl shadow-black/30 backdrop-blur-sm sm:p-8"
    >
      <div class="mb-8 flex items-center gap-2">
        <span class="h-3 w-3 rounded-full bg-zinc-600"></span>
        <span class="h-3 w-3 rounded-full bg-zinc-600"></span>
        <span class="h-3 w-3 rounded-full bg-brand-400"></span>
      </div>

      <div class="space-y-5 font-mono text-sm">
        <p>
          <span class="text-brand-400">const</span>
          <span class="text-zinc-100"> developer</span>
          <span class="text-zinc-500"> = {`{`}</span>
        </p>

        <div class="space-y-3 pl-5 text-zinc-400">
          <p>
            name:
            <span class="text-zinc-100">'Julio Andrei'</span>,
          </p>

          <p>
            location:
            <span class="text-zinc-100">'Puebla, Mexico'</span>,
          </p>

          <p>
            focus:
            <span class="text-zinc-100">'Useful software'</span>,
          </p>

          <p>
            available:
            <span class="text-brand-400">true</span>
          </p>
        </div>

        <p class="text-zinc-500">{`}`};</p>
      </div>
    </aside>
  </div>
</section>
