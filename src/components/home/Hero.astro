---
import LocalTime from "../ui/LocalTime.astro";

interface Props {
  lang?: "en" | "es";
}

const { lang = "en" } = Astro.props;

const content = {
  en: {
    eyebrow: "Freelance software developer",
    titleStart: "Digital products built with",
    titleAccent: "purpose",
    titleEnd: "not noise.",
    description:
      "I design and develop professional websites, web applications, APIs, and mobile experiences for businesses and growing teams.",
    primaryCta: "Explore my work",
    secondaryCta: "Start a project",
    primaryHref: "/en/projects",
    secondaryHref: "/en/contact",
    codeName: "Julio Andrei",
    codeLocation: "Puebla, Mexico",
    codeFocus: "Useful software",
  },
  es: {
    eyebrow: "Desarrollador de software freelance",
    titleStart: "Productos digitales construidos con",
    titleAccent: "propósito",
    titleEnd: "no ruido.",
    description:
      "Diseño y desarrollo sitios web profesionales, aplicaciones web, APIs y experiencias móviles para negocios, profesionales independientes y equipos en crecimiento.",
    primaryCta: "Ver proyectos",
    secondaryCta: "Iniciar proyecto",
    primaryHref: "/es/proyectos",
    secondaryHref: "/es/contacto",
    codeName: "Julio Andrei",
    codeLocation: "Puebla, México",
    codeFocus: "Software útil",
  },
}[lang];
---

<section class="relative overflow-hidden">
  <div
    class="mx-auto grid w-full max-w-7xl items-center gap-14 px-5 py-20 sm:px-8 sm:py-28 lg:grid-cols-[1.2fr_0.8fr] lg:px-10 lg:py-36"
  >
    <div>
      <div class="mb-8 xl:hidden">
        <LocalTime />
      </div>

      <p
        class="mb-5 font-mono text-sm font-semibold uppercase tracking-[0.18em] text-brand-400"
      >
        {content.eyebrow}
      </p>

      <h1
        class="max-w-4xl text-4xl font-semibold leading-[1.08] tracking-[-0.04em] text-white sm:text-6xl lg:text-7xl"
      >
        {content.titleStart}{" "}
        <span class="text-brand-400">{content.titleAccent}</span>,
        {content.titleEnd}
      </h1>

      <p class="mt-7 max-w-2xl text-base leading-8 text-zinc-400 sm:text-lg">
        {content.description}
      </p>

      <div class="mt-10 flex flex-col gap-3 sm:flex-row">
        <a
          href={content.primaryHref}
          class="inline-flex min-h-12 items-center justify-center rounded-full bg-brand-400 px-6 font-semibold text-zinc-950 transition hover:bg-brand-300"
        >
          {content.primaryCta}
        </a>

        <a
          href={content.secondaryHref}
          class="inline-flex min-h-12 items-center justify-center rounded-full border border-white/12 bg-white/[0.03] px-6 font-semibold text-white transition hover:border-white/25 hover:bg-white/[0.06]"
        >
          {content.secondaryCta}
        </a>
      </div>
    </div>

    <aside
      class="rounded-3xl border border-white/10 bg-white/[0.035] p-6 shadow-2xl shadow-black/30 backdrop-blur-sm sm:p-8"
    >
      <div class="mb-8 flex items-center gap-2">
        <span class="h-3 w-3 rounded-full bg-zinc-600"></span>
        <span class="h-3 w-3 rounded-full bg-zinc-600"></span>
        <span class="h-3 w-3 rounded-full bg-brand-400"></span>
      </div>

      <div class="space-y-5 font-mono text-sm">
        <p>
          <span class="text-brand-400">const</span>
          <span class="text-zinc-100"> developer</span>
          <span class="text-zinc-500"> = {`{`}</span>
        </p>

        <div class="space-y-3 pl-5 text-zinc-400">
          <p>
            name:
            <span class="text-zinc-100">'{content.codeName}'</span>,
          </p>

          <p>
            location:
            <span class="text-zinc-100">'{content.codeLocation}'</span>,
          </p>

          <p>
            focus:
            <span class="text-zinc-100">'{content.codeFocus}'</span>,
          </p>

          <p>
            available:
            <span class="text-brand-400">true</span>
          </p>
        </div>

        <p class="text-zinc-500">{`}`};</p>
      </div>
    </aside>
  </div>
</section>
