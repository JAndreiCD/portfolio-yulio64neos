---
import { getCollection } from "astro:content";

const projects = await getCollection("projects", ({ data }) => {
  return data.featured === true;
});
---

<section class="border-t border-white/8">
  <div class="mx-auto w-full max-w-7xl px-5 py-20 sm:px-8 lg:px-10 lg:py-28">
    <div
      class="mb-12 flex flex-col gap-6 md:flex-row md:items-end md:justify-between"
    >
      <div>
        <p
          class="font-mono text-sm font-semibold uppercase tracking-[0.18em] text-brand-400"
        >
          Selected work
        </p>

        <h2
          class="mt-5 max-w-2xl text-3xl font-semibold leading-tight tracking-[-0.03em] text-white sm:text-5xl"
        >
          Projects with clear goals and practical execution.
        </h2>
      </div>

      <a
        href="/projects"
        class="inline-flex min-h-12 w-fit items-center justify-center rounded-full border border-white/12 bg-white/[0.03] px-6 font-semibold text-white transition hover:border-brand-400/50 hover:bg-brand-400/10 hover:text-brand-300"
      >
        View all projects
      </a>
    </div>

    <div class="grid gap-5 lg:grid-cols-2">
      {
        projects.map((project) => (
          <article class="group rounded-3xl border border-white/10 bg-white/[0.025] p-6 transition duration-300 hover:-translate-y-1 hover:border-brand-400/40 hover:bg-white/[0.04] sm:p-8">
            <div class="mb-8 flex min-h-52 items-center justify-center rounded-2xl border border-white/10 bg-zinc-950/60">
              <div class="text-center">
                <p class="font-mono text-sm text-brand-400">Project preview</p>
                <p class="mt-2 text-sm text-zinc-500">
                  Visual assets coming soon
                </p>
              </div>
            </div>

            <div class="flex flex-col gap-5">
              <div>
                <h3 class="text-2xl font-semibold tracking-tight text-white">
                  {project.data.title}
                </h3>

                <p class="mt-4 max-w-2xl leading-7 text-zinc-400">
                  {project.data.description}
                </p>
              </div>

              <div class="flex flex-wrap gap-2">
                {project.data.technologies.map((technology) => (
                  <span class="rounded-full border border-white/10 bg-white/[0.035] px-3 py-1 text-xs font-medium text-zinc-400">
                    {technology}
                  </span>
                ))}
              </div>

              <a
                href={`/projects/${project.id}`}
                class="inline-flex w-fit items-center gap-2 font-semibold text-brand-400 transition hover:text-brand-300"
              >
                Read case study
                <span aria-hidden="true">→</span>
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
