---
import LocalTime from "../ui/LocalTime.astro";

const currentPath = Astro.url.pathname;

const isSpanish = currentPath === "/es" || currentPath.startsWith("/es/");
const lang = isSpanish ? "es" : "en";

const navigation = isSpanish
  ? [
      { label: "Inicio", href: "/es" },
      { label: "Servicios", href: "/es/servicios" },
      { label: "Proyectos", href: "/es/proyectos" },
      { label: "Blog", href: "/es/blog" },
      { label: "Sobre mí", href: "/es/sobre-mi" },
    ]
  : [
      { label: "Home", href: "/en" },
      { label: "Services", href: "/en/services" },
      { label: "Projects", href: "/en/projects" },
      { label: "Blog", href: "/en/blog" },
      { label: "About", href: "/en/about" },
    ];

const contactHref = isSpanish ? "/es/contacto" : "/en/contact";
const ctaLabel = isSpanish ? "Iniciar proyecto" : "Start a project";

const languageSwitch = isSpanish
  ? { label: "EN", href: "/en", ariaLabel: "Switch to English" }
  : { label: "ES", href: "/es", ariaLabel: "Cambiar a español" };

function isActivePath(href: string) {
  return href === "/es" || href === "/en"
    ? currentPath === href
    : currentPath.startsWith(href);
}
---

<header
  class="sticky top-0 z-50 border-b border-white/8 bg-[#090b0d]/85 backdrop-blur-xl"
>
  <div
    class="mx-auto flex min-h-20 w-full max-w-7xl items-center justify-between gap-6 px-5 sm:px-8 lg:px-10"
  >
    <a
      href={isSpanish ? "/es" : "/en"}
      class="shrink-0 font-mono text-sm font-bold tracking-tight text-white sm:text-base"
      aria-label="Yulio64neos home"
    >
      <span class="text-brand-400">&lt;</span>
      Yulio64neos
      <span class="text-brand-400">/&gt;</span>
    </a>

    <nav class="hidden items-center gap-6 lg:flex" aria-label="Main navigation">
      {
        navigation.map((item) => {
          const isActive = isActivePath(item.href);

          return (
            <a
              href={item.href}
              class:list={[
                "text-sm transition-colors hover:text-white",
                isActive ? "text-white" : "text-zinc-400",
              ]}
              aria-current={isActive ? "page" : undefined}
            >
              {item.label}
            </a>
          );
        })
      }
    </nav>

    <div class="hidden xl:block">
      <LocalTime />
    </div>

    <div class="hidden items-center gap-3 lg:flex">
      <a
        href={languageSwitch.href}
        aria-label={languageSwitch.ariaLabel}
        class="rounded-full border border-white/10 bg-white/[0.03] px-3 py-2 text-xs font-semibold text-zinc-300 transition hover:border-brand-400/40 hover:bg-brand-400/10 hover:text-brand-300"
      >
        {languageSwitch.label}
      </a>

      <a
        href={contactHref}
        class="rounded-full bg-brand-400 px-4 py-2 text-sm font-semibold text-zinc-950 transition hover:bg-brand-300 focus:outline-none focus:ring-2 focus:ring-brand-300 focus:ring-offset-2 focus:ring-offset-zinc-950"
      >
        {ctaLabel}
      </a>
    </div>

    <details class="mobile-nav relative lg:hidden">
      <summary
        class="flex h-11 w-11 cursor-pointer list-none items-center justify-center rounded-full border border-white/10 bg-white/[0.03] text-white transition hover:border-brand-400/40 hover:bg-brand-400/10"
        aria-label="Toggle navigation menu"
      >
        <svg
          class="icon-menu h-5 w-5"
          viewBox="0 0 24 24"
          fill="none"
          aria-hidden="true"
        >
          <path
            d="M4 7h16M4 12h16M4 17h16"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"></path>
        </svg>

        <svg
          class="icon-close h-5 w-5"
          viewBox="0 0 24 24"
          fill="none"
          aria-hidden="true"
        >
          <path
            d="M6 6l12 12M18 6L6 18"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"></path>
        </svg>
      </summary>

      <div
        class="absolute right-0 top-14 w-[min(22rem,calc(100vw-2.5rem))] rounded-3xl border border-white/10 bg-[#090b0d] p-5 shadow-2xl shadow-black/50"
      >
        <div class="mb-5">
          <LocalTime />
        </div>

        <nav class="grid gap-2" aria-label="Mobile navigation">
          {
            navigation.map((item) => {
              const isActive = isActivePath(item.href);

              return (
                <a
                  href={item.href}
                  class:list={[
                    "rounded-2xl px-4 py-3 text-sm font-medium transition",
                    isActive
                      ? "bg-brand-400/10 text-brand-300"
                      : "text-zinc-400 hover:bg-white/[0.04] hover:text-white",
                  ]}
                  aria-current={isActive ? "page" : undefined}
                >
                  {item.label}
                </a>
              );
            })
          }
        </nav>

        <div class="mt-5 grid grid-cols-[auto_1fr] gap-3">
          <a
            href={languageSwitch.href}
            aria-label={languageSwitch.ariaLabel}
            class="inline-flex min-h-12 items-center justify-center rounded-full border border-white/10 bg-white/[0.03] px-5 font-semibold text-zinc-300 transition hover:border-brand-400/40 hover:bg-brand-400/10 hover:text-brand-300"
          >
            {languageSwitch.label}
          </a>

          <a
            href={contactHref}
            class="inline-flex min-h-12 items-center justify-center rounded-full bg-brand-400 px-6 font-semibold text-zinc-950 transition hover:bg-brand-300"
          >
            {ctaLabel}
          </a>
        </div>
      </div>
    </details>
  </div>
</header>
